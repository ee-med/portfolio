# SQLite connection string (single file, created on first run).
# For Docker/self-host, point this at a path on a persistent volume.
DATABASE_URL=file:./portfolio.db

# Secret used to sign/encrypt Payload tokens. Generate a long random value:
#   openssl rand -hex 32
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Public base URL of the site. Used for absolute OG/canonical URLs.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# n8n webhook that receives contact submissions (auto-reply + notification).
# Leave unset to disable the automation; submissions still save to the DB.
N8N_CONTACT_WEBHOOK_URL=http://localhost:5678/webhook/contact

# Self-hosted cal.com booking embed (/book page). Leave unset to show a
# "scheduler offline" placeholder instead of the widget.
NEXT_PUBLIC_CAL_LINK=your-username/30min
NEXT_PUBLIC_CAL_ORIGIN=http://localhost:3002

# Umami analytics tracker. Leave unset to disable (no script loaded).
# Website ID comes from the Umami dashboard after creating a website.
NEXT_PUBLIC_UMAMI_SRC=http://localhost:3003/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
