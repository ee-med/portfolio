# ── Shared ──────────────────────────────────────────────────────────────
TZ=Europe/Madrid

# ── Nginx / public hosts ───────────────────────────────────────────────
DOMAIN=yourdomain.com
PORTAINER_SUBDOMAIN=portainer
N8N_SUBDOMAIN=automation
CALCOM_SUBDOMAIN=book
UMAMI_SUBDOMAIN=analytics

# ── n8n ─────────────────────────────────────────────────────────────────
N8N_HOST=automation.yourdomain.com
N8N_PROTOCOL=https
# Public base URL n8n advertises for webhooks (use your domain behind a proxy).
N8N_WEBHOOK_URL=https://automation.yourdomain.com/
# Generate once and keep stable: openssl rand -hex 24
N8N_ENCRYPTION_KEY=change-me

# Resend (used by the contact workflow). Get a key at https://resend.com and
# verify your sending domain. CONTACT_FROM_EMAIL must be on a verified domain.
RESEND_API_KEY=re_your_key_here
CONTACT_FROM_EMAIL=Portfolio <hello@yourdomain.com>
CONTACT_NOTIFY_TO=you@yourdomain.com

# ── cal.com ──────────────────────────────────────────────────────────────
# Public URL of the cal.com instance (behind a proxy in prod, e.g. https://cal.yourdomain.com)
NEXT_PUBLIC_WEBAPP_URL=https://book.yourdomain.com
NEXTAUTH_SECRET=            # openssl rand -base64 32
CALENDSO_ENCRYPTION_KEY=    # openssl rand -base64 24  — NEVER change after first run
CAL_POSTGRES_USER=calcom
CAL_POSTGRES_PASSWORD=change-me
CAL_POSTGRES_DB=calcom
# Host allowed to embed the booking page (the portfolio). Bare host, no quotes
# (compose adds them). For multiple hosts: localhost:3000","yourdomain.com
CAL_ALLOWED_HOSTNAMES=yourdomain.com

# Optional: let cal.com send booking emails via Resend's SMTP bridge.
CAL_EMAIL_FROM=bookings@yourdomain.com
CAL_EMAIL_SERVER_HOST=smtp.resend.com
CAL_EMAIL_SERVER_PORT=465
CAL_EMAIL_SERVER_USER=resend
CAL_EMAIL_SERVER_PASSWORD=re_your_key_here

# ── Umami (analytics) ────────────────────────────────────────────────────
UMAMI_POSTGRES_PASSWORD=change-me
# openssl rand -hex 32
UMAMI_APP_SECRET=change-me

# ── Portfolio ────────────────────────────────────────────────────
# openssl rand -hex 32
PAYLOAD_SECRET=change-me
NEXT_PUBLIC_SERVER_URL=https://yourdomain.com
NEXT_PUBLIC_CAL_LINK=your-username/30min
NEXT_PUBLIC_CAL_ORIGIN=https://book.yourdomain.com
NEXT_PUBLIC_UMAMI_SRC=https://analytics.yourdomain.com/script.js
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
